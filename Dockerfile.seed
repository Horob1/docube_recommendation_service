# Seed runner — builds and runs the seed script
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ libpq-dev && \
    rm -rf /var/lib/apt/lists/*

# Install only seed dependencies
RUN pip install --no-cache-dir asyncpg numpy sentence-transformers

COPY tests/seed/ ./tests/seed/
COPY schema.sql .

CMD ["python", "-m", "tests.seed.seed_data"]
